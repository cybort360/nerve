# Google Cloud / Gemini
# GCP project ID — find in Google Cloud Console
GOOGLE_CLOUD_PROJECT=
# Region for Gemini API calls
GOOGLE_CLOUD_LOCATION=us-central1
# Gemini model string
GEMINI_MODEL=gemini-2.5-flash
# Use Google Search grounding in the Incident Autopilot reasoning step.
# Requires GOOGLE_CLOUD_PROJECT and Vertex AI API enabled. Set false for
# offline/demo use to fall back to ungrounded reasoning.
GEMINI_GROUNDING_ENABLED=true
# Store/retrieve past incident patterns via Vertex AI Memory Bank (opt-in).
# Disabled by default; store/retrieve are no-ops when off.
MEMORY_BANK_ENABLED=false
# Create a Memory Bank in Google Cloud Console > Agent Platform > Memory Bank,
# then paste the ID here.
MEMORY_BANK_ID=

# MongoDB
# Atlas connection string — get from Atlas > Connect > Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Database name
MONGODB_DATABASE=nerve

# Dynatrace
# Your Dynatrace environment URL (no trailing slash)
DYNATRACE_ENVIRONMENT_URL=
# API token — needs: Read problems, Read metrics, Read entities
DYNATRACE_API_TOKEN=
# Shared secret for validating the Dynatrace problem webhook (see
# docs/dynatrace_webhook_setup.md). Generate one with:  openssl rand -hex 32
# Paste the SAME value here and as a custom request header in Dynatrace:
#   Header name: X-Dynatrace-Signature   Header value: <this secret>
# Leave blank to reject all webhook calls (receiver disabled).
DYNATRACE_WEBHOOK_SECRET=

# GitLab
# GitLab instance URL (use https://gitlab.com for SaaS)
GITLAB_URL=https://gitlab.com
# Personal access token — needs: api scope
GITLAB_TOKEN=
# Default project ID to operate on (numeric id, e.g. 12345).
# Get one by provisioning the demo project:
#     python scripts/setup_gitlab_demo.py
# It creates "nerve-demo-service" (with a seeded deployment + a payment_processor.py
# commit) and prints the GITLAB_PROJECT_ID to paste here.
# NOTE: in DEMO_MODE the workflow creates a REAL GitLab issue in this project when a
# real token + project id are set; otherwise it falls back to seeded GitLab (offline).
GITLAB_PROJECT_ID=

# Web Search (Tavily) — required for GENERAL research missions.
# Get a free key at https://app.tavily.com (free tier ~1,000 searches/month).
TAVILY_API_KEY=
# Optional: max results per search (default 5).
WEB_SEARCH_MAX_RESULTS=5

# Orchestrator
# Seconds between orchestration loop cycles
ORCHESTRATION_INTERVAL_SECONDS=30
# Risk score (0.0-1.0) that triggers replanning
RISK_THRESHOLD=0.7
# Max retries per task before marking failed
MAX_TASK_RETRIES=3

# Telegram (mobile approvals + notifications)
# Create a bot via @BotFather on Telegram, paste token here.
TELEGRAM_BOT_TOKEN=
# Get your chat ID by messaging @userinfobot.
TELEGRAM_CHAT_ID=
# Set to true to enable the Telegram bot (opt-in). When false, all bot calls
# are no-ops and no polling loop is started.
TELEGRAM_ENABLED=false

# Feature Flags
# Set to true to enable failure injection (demo and testing only)
FAILURE_ENGINE_ENABLED=false
# Set to true to run the scripted demo scenario
DEMO_MODE=false

# Auth — HS256 session signing key. Generate one with: openssl rand -hex 32
# If unset, sessions are ephemeral (drop on restart / don't span instances).
JWT_SECRET=
JWT_EXPIRE_MINUTES=10080
# Set false only for local http testing with curl (default true is correct on https).
COOKIE_SECURE=true

# Email of the user account that owns Dynatrace-webhook incidents (they have no
# logged-in user). The dashboard shows these incidents only to that user. Empty => unowned.
INCIDENTS_OWNER_EMAIL=
